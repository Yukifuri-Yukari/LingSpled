package sqrt.second

class 平方秒 {
    override fun toString(): String {
        return "平方秒"
    }
}

class 立方吨 {
    override fun toString(): String {
        return "立方吨"
    }
}

class 平方喵(
    val pfm: 平方秒,
    val lfd: 立方吨,
) {
    static val designSqrtSecond = { { { 平方喵(平方秒(), 立方吨()) } }() }

    fun 喵叫() {
        println("咪咪嗷嗷~ -- ${pfm}和${lfd}")
    }

    fun 称呼人格(): String { return "咱" }

    fun 属性(): String { return "天生鬼才" }
}

fun main(arg: Array<String>) {
    /* D E S I G N A N T . */
    val 平方喵 = 平方喵.designSqrtSecond()()
    平方喵

    平方喵.喵叫()

    println(
        平方喵
    )

    println(
        平方喵.pfm,
        "和",
        平方喵.lfd,
    )

    val 颜文字 = "ovo"

    println("${平方喵.称呼人格()}是${平方喵.属性()} $颜文字")
}
