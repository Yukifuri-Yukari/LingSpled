class Point(val x: Int, val y: Int) {
    fun lengthSquared(): Int {
        return x * x + y * y
    }
}

class Counter(var count: Int = 0) {
    constructor() : this(0)

    fun increment(): Unit {
        count = count + 1
    }
}

class Shape(val name: String) {
    fun describe(): String {
        return name
    }

    static fun from(name: String) = Shape(name)
}

class NamedPoint(val x: Int, val y: Int) : Shape("point"), Comparable<NamedPoint> {
    override fun compareTo(other: NamedPoint): Int {
        return x - other.x
    }
}

class Box<T : Any>(private val value: T) {
    fun get(): T {
        return value
    }
}

class Token private constructor(val raw: String) {
    constructor() : this("")
}

class Config(source: Lookup) {
    val host: String by source
    var port: Int by Delegates.observable(8080)
}

class Temperature(var celsius: Double) {
    // 只读属性 + 表达式体 getter（无幕后字段）
    val fahrenheit: Double
        get() = celsius * 9.0 / 5.0 + 32.0

    // 读写属性 + getter/setter + field 幕后字段，顺序不限
    var label: String = ""
        get() = field
        set(value) {
            field = value
        }

    var quiet: Int = 0
        set(value) { field = value }
        get() = field
}

public fun lambdas(items: Array<Int>) {
    // lambda 字面量：类型标注 / 显式多参 / 空 / 隐式 it
    val double = { x: Int -> x * 2 }
    val add = { a, b -> a + b }
    val noop = { }
    val toStr = { it.toString() }

    // trailing lambda
    items.forEach { println(it) }
    val sum = items.fold(0) { acc, x -> acc + x }
    run { println("trailing") }

    // a(...) 换行后的 {} 不是 trailing：拆成 invoke 语句 + 独立 lambda 语句
    println("done")
    { println("standalone") }
}

class Resource(val path: String) {
    val handle: Int

    // 多个 init 块按源序执行
    init {
        handle = open(path)
        println("opened")
    }

    init {
        register(handle)
    }

    // 析构前调用，每类至多一个
    deinit {
        close(handle)
    }

    // 嵌套类
    class Builder {
        var path: String = ""

        fun build(): Resource {
            return Resource(path)
        }
    }
}