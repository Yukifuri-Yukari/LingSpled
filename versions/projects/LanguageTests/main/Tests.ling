class Empty

class Repo<T> : Iterable<T> where T : Any

data class Pair2<A, B>(val first: A, val second: B)

@Deprecated("use Token instead")
class LegacyToken(@Deprecated val raw: String)

class Point(val x: Int, val y: Int) {
    fun lengthSquared(): Int {
        return x * x + y * y
    }
}

class Counter(var count: Int = 0) {
    constructor() : this(0)

    fun increment(): Unit {
        count = count + 1
    }
}

class Shape(val name: String) {
    fun describe(): String {
        return name
    }
}

class NamedPoint(val x: Int, val y: Int) : Shape("point"), Comparable<NamedPoint> {
    override fun compareTo(other: NamedPoint): Int {
        return x - other.x
    }
}

class Box<T : Any>(private val value: T) {
    fun get(): T {
        return value
    }
}

class Token private constructor(val raw: String) {
    constructor() : this("")
}