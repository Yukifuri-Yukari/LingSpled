public fun controlFlow(n: Int, items: Array<Int>): Int {
    val sign = if (n > 0) 1 else if (n < 0) -1 else 0

    if (n > 100) {
        println("big")
    } else if (n > 10) {
        println("medium")
    } else {
        println("small")
    }

    var i = 0
    while (i < n) {
        if (i == 5) break
        i++
    }

    do {
        i--
    } while (i > 0)

    var sum = 0
    for (x in items) {
        if (x < 0) continue
        sum += x
    }
    for (j: Int in items) {
        sum += j
    }

    for (k in 0..n) {
        sum += k
    }
    for (m in 0..<n) {
        sum -= m
    }

    try {
        if (sum < 0) throw RuntimeException("negative")
    } catch (e: Exception) {
        sum = 0
    } finally {
        println("done")
    }

    return sum + sign
}

class Empty

class Repo<T> : Iterable<T> where T : Any

data class Pair2<A, B>(val first: A, val second: B)

