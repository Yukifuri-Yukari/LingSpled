package ling.std

class String(
    var arr: Array<Char> = Array(0)
) {

    constructor(other: String) : this(other.arr)

    val size get() = arr.size
    val length get() = size

    operator fun plus(other: Any) = String(arr + other.toString().arr)

    override fun toString() = arr.joinToString("")
}

class StringBuilder : IndexedCollection<Char> {
    ...
}
